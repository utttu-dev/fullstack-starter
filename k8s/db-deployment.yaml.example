# ----------------------------------------
# db-deployment.yaml.example
# ----------------------------------------
# DBをk8s上で動かす構成。機密情報はSecretで管理する。

apiVersion: v1
kind: Secret
metadata:
  name: <APP_NAME>-db-secret
type: Opaque
stringData:
  DB_ROOT_PASSWORD: <DB_ROOT_PASSWORD>
  DB_NAME: <DB_NAME>
  DB_USER: <DB_USER>
  DB_PASSWORD: <DB_PASSWORD>
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: <APP_NAME>-db
spec:
  replicas: 1
  selector:
    matchLabels:
      app: <APP_NAME>-db
  template:
    metadata:
      labels:
        app: <APP_NAME>-db
    spec:
      containers:
        - name: <APP_NAME>-db
          image: <DB_IMAGE>   # 例: mysql:8.0
          ports:
            - containerPort: <DB_PORT>
          envFrom:
            - secretRef:
                name: <APP_NAME>-db-secret
          readinessProbe:
            exec:
              command:
                - <DB_HEALTHCHECK_COMMAND>
                # 例(MySQL): mysqladmin, ping, -h, localhost
            initialDelaySeconds: 10
            periodSeconds: 5
---
apiVersion: v1
kind: Service
metadata:
  name: <APP_NAME>-db-service
spec:
  selector:
    app: <APP_NAME>-db
  ports:
    - protocol: TCP
      port: <DB_PORT>
      targetPort: <DB_PORT>
  type: ClusterIP